#!/bin/bash

# Script to connect to EC2 instances via AWS Systems Manager Session Manager
# Usage: aws-ssm-session <stage> [--attributes <attributes>] [-- COMMAND]
#
# Instances are identified by the Stage tag (same as aws-list/aws-ssh), with Attributes=manager default.
# Optionally pass a command after -- to run non-interactively via ssm send-command, e.g.:
#   aws-ssm-session dev-ecs -- docker ps
#   aws-ssm-session dev-ecs -- "cd /some/path && my-command"

# Source common functions
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/aws-scripts-common.sh"

stage=""
attributes="manager"  # Default to manager (same as aws-list)
profile="${AWS_PROFILE:-default}"
remote_command=()

# Split args on -- to separate session args from the remote command
session_args=()
found_separator=false

for arg in "$@"; do
    if [ "$found_separator" = true ]; then
        remote_command+=("$arg")
    elif [ "$arg" = "--" ]; then
        found_separator=true
    else
        session_args+=("$arg")
    fi
done

# Parse session args
set -- "${session_args[@]}"
while (( "$#" )); do
    case "$1" in
        --stage)
            if [ -n "$2" ] && [ ${2:0:1} != "-" ]; then
                stage="$2"
                shift 2
            else
                echo "Error: Argument for $1 is missing" >&2
                exit 1
            fi
            ;;
        --attributes)
            if [ -n "$2" ] && [ ${2:0:1} != "-" ]; then
                attributes="$2"
                shift 2
            else
                echo "Error: Argument for $1 is missing" >&2
                exit 1
            fi
            ;;
        --profile)
            if [ -n "$2" ] && [ ${2:0:1} != "-" ]; then
                profile="$2"
                shift 2
            else
                echo "Error: Argument for $1 is missing" >&2
                exit 1
            fi
            ;;
        *)
            if [ -z "$stage" ]; then
                stage="$1"
            else
                echo "Error: Multiple stage names provided" >&2
                exit 1
            fi
            shift
            ;;
    esac
done

if [ -z "$stage" ]; then
    echo "Usage: aws-ssm-session <stage> [--attributes <attributes>] [-- COMMAND]"
    echo "  Default attributes: 'manager'"
    exit 1
fi

# Check AWS authentication
check_aws_auth "$profile"

# Build filters array
filters=("Name=instance-state-name,Values=running")

if [ -n "$stage" ]; then
    filters+=("Name=tag:Stage,Values=$stage")
fi

if [ -n "$attributes" ]; then
    filters+=("Name=tag:Attributes,Values=$attributes")
fi

instance_info=$(aws ec2 describe-instances \
    --profile "$profile" \
    --filters "${filters[@]}" \
    --query 'Reservations[].Instances[0].{id:InstanceId,name:Tags[?Key==`Name`].Value | [0]}' \
    --output json | python3 -c "import sys,json; d=json.load(sys.stdin); r=d[0] if d else {}; print(r.get('id',''), r.get('name',''))" 2>/dev/null)

instance_id=$(echo "$instance_info" | awk '{print $1}')
instance_name=$(echo "$instance_info" | awk '{$1=""; print substr($0,2)}')

if [ "$instance_id" = "None" ] || [ -z "$instance_id" ]; then
    echo "Instance with stage '$stage' not found or not running with the specified filters." >&2
    echo "  Stage: $stage" >&2
    echo "  Attributes: $attributes" >&2
    exit 1
fi

if [ ${#remote_command[@]} -gt 0 ]; then
    # Non-interactive: run command via send-command and stream output
    command_str="${remote_command[*]}"

    command_id=$(aws ssm send-command \
        --profile "$profile" \
        --instance-ids "$instance_id" \
        --document-name "AWS-RunShellScript" \
        --parameters "commands=[\"$command_str\"]" \
        --query 'Command.CommandId' \
        --output text)

    if [ -z "$command_id" ]; then
        echo "Error: Failed to send command" >&2
        exit 1
    fi

    # Poll until the command finishes
    while true; do
        status=$(aws ssm get-command-invocation \
            --profile "$profile" \
            --command-id "$command_id" \
            --instance-id "$instance_id" \
            --query 'Status' \
            --output text 2>/dev/null)

        case "$status" in
            Success|Failed|Cancelled|TimedOut|DeliveryTimedOut|ExecutionTimedOut)
                break
                ;;
        esac
        sleep 1
    done

    # Print stdout and stderr
    result=$(aws ssm get-command-invocation \
        --profile "$profile" \
        --command-id "$command_id" \
        --instance-id "$instance_id" \
        --query '{stdout: StandardOutputContent, stderr: StandardErrorContent, rc: ResponseCode}' \
        --output json)

    stdout=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['stdout'], end='')")
    stderr=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['stderr'], end='')")
    rc=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['rc'])")

    [ -n "$stdout" ] && echo "$stdout"
    [ -n "$stderr" ] && echo "$stderr" >&2

    exit "$rc"
else
    echo "Connecting to instance: $instance_name (ID: $instance_id, Stage: $stage)"
    aws ssm start-session --target "$instance_id" --profile "$profile"
fi
